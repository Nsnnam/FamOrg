# ─── Ports (NAS) ─────────────────────────────────────────────────────────────
# Local: truy cập trong LAN / từ chính NAS
# Public: port mở trên host (router forward hoặc reverse proxy)
LOCAL_PORT=3576
PUBLIC_PORT=8561

# ─── Gemini AI (tuỳ chọn) ────────────────────────────────────────────────────
# Lấy tại: https://aistudio.google.com/app/apikey
# Hoặc nhập sau trong Settings → Thiết lập AI
GEMINI_API_KEY=

# ─── URL truy cập ứng dụng (HTTPS mặc định) ──────────────────────────────────
# Dùng cho deep-link thông báo đẩy. Nên là URL public HTTPS (reverse proxy).
# Ví dụ:
#   https://namns.i234.me
#   https://family.yourdomain.com
# LAN (chỉ khi không có reverse proxy HTTPS):
#   https://192.168.1.89:3576   (nếu tự ký cert)
APP_URL=https://namns.i234.me

# ─── Watchtower (nút "Cập nhật ngay") ───────────────────────────────────────
# Tạo token: openssl rand -hex 24
WATCHTOWER_HTTP_API_TOKEN=change_me_to_a_random_secret

# ─── Repo GitHub (kiểm tra phiên bản mới) ───────────────────────────────────
GITHUB_REPO=Nsnnam/FamOrg

# ─── Web Push VAPID (tuỳ chọn) ───────────────────────────────────────────────
# Sinh bằng: npx web-push generate-vapid-keys
# Để trống nếu chưa cần thông báo đẩy PWA
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
