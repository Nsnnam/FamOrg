# Khóa Gemini API — bắt buộc nếu dùng tính năng AI assistant và phân tích.
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Địa chỉ truy cập ứng dụng từ bên ngoài.
# Ví dụ: https://family.yourdomain.com hoặc URL Tailscale của bạn.
APP_URL=https://your-domain-or-tailscale-url

# Token xác thực cho Watchtower HTTP API (dùng cho nút "Cập nhật ngay" trong Settings).
# Tự đặt chuỗi ngẫu nhiên bất kỳ, ví dụ: openssl rand -hex 24
WATCHTOWER_HTTP_API_TOKEN=your_secret_token_here
