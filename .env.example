# Khóa Gemini API — bắt buộc nếu dùng tính năng AI assistant và phân tích.
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Địa chỉ truy cập ứng dụng từ bên ngoài.
# Ví dụ: https://family.yourdomain.com hoặc URL Tailscale của bạn.
APP_URL=https://your-domain-or-tailscale-url

# Token xác thực cho Watchtower HTTP API (dùng cho nút "Cập nhật ngay" trong Settings).
# Tự đặt chuỗi ngẫu nhiên bất kỳ, ví dụ: openssl rand -hex 24
WATCHTOWER_HTTP_API_TOKEN=your_secret_token_here

# Web Push (VAPID) — bật thông báo đẩy cho PWA (banner hệ thống + badge số trên icon).
# Sinh MỘT LẦN bằng: node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
# Dùng CÙNG một cặp khóa ở mọi nơi chạy app (máy dev + Raspberry Pi). Đổi khóa => mọi đăng ký cũ mất hiệu lực.
# Để trống cả 3 dòng nếu chưa muốn bật thông báo đẩy — app vẫn chạy bình thường, chỉ là không đẩy ra hệ thống.
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:you@example.com
