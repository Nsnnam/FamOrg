# ─── Ports (NAS) ─────────────────────────────────────────────────────────────
# Local: truy cập trong LAN / từ chính NAS
# Public: port mở ra ngoài (router port-forward hoặc firewall NAS)
LOCAL_PORT=3576
PUBLIC_PORT=8561

# ─── Gemini AI (tuỳ chọn) ────────────────────────────────────────────────────
# Lấy tại: https://aistudio.google.com/app/apikey
# Hoặc nhập sau trong Settings → Thiết lập AI
GEMINI_API_KEY=

# ─── URL truy cập ứng dụng ───────────────────────────────────────────────────
# Dùng cho deep-link thông báo đẩy. Ví dụ:
#   http://192.168.x.x:3576          (LAN)
#   http://your-public-ip:8561       (public, HTTP)
#   https://family.yourdomain.com    (nếu có reverse proxy HTTPS)
APP_URL=http://YOUR_NAS_IP:3576

# ─── Watchtower (nút "Cập nhật ngay") ───────────────────────────────────────
# Tạo token: openssl rand -hex 24
WATCHTOWER_HTTP_API_TOKEN=change_me_to_a_random_secret

# ─── Repo GitHub (kiểm tra phiên bản mới) ───────────────────────────────────
GITHUB_REPO=Nsnnam/FamOrg

# ─── Web Push VAPID (tuỳ chọn) ───────────────────────────────────────────────
# Sinh bằng: npx web-push generate-vapid-keys
# Để trống nếu chưa cần thông báo đẩy PWA
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
